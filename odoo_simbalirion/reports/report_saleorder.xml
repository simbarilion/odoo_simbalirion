<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_saleorder_custom" inherit_id="sale.report_saleorder_document">
        <xpath expr="//div[@class='page']/div[1]" position="before">
            <t t-if="doc.new_field">
                <p><strong>New Field:</strong> <t t-esc="doc.new_field"/></p>
            </t>
            <t t-if="not doc.new_field">
                <p>Поле New Field пустое!</p>
            </t>
        </xpath>
    </template>
</odoo>
