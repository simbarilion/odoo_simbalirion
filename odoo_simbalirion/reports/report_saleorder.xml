<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_saleorder_custom" inherit_id="sale.report_saleorder_document">
        <xpath expr="//table[contains(@class, 'table')]" position="before">
            <t t-if="doc.new_field">
                <p><strong>New Field:</strong> <t t-esc="doc.new_field"/></p>
            </t>
            <t t-else="">
                <p><strong>Поле New Field пустое!</strong></p>
            </t>
        </xpath>
    </template>
</odoo>
