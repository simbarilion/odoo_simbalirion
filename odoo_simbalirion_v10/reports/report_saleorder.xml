<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="sale_order_new_field_report" inherit_id="sale.report_saleorder_document">
        <xpath expr="//div[hasclass('page')]//table" position="before">
            <div class="mt-4 mb-4">
                <t t-if="doc.new_field">
                    <p class="fw-bold" t-esc="doc.new_field"/>
                </t>
                <t t-else="">
                    <p class="text-danger fw-bold">Поле New Field пустое!!!</p>
                </t>
            </div>
        </xpath>

    </template>
</odoo>
